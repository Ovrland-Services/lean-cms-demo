<% content_for :title, "Trips — Slothback Outfitters" %>

<%= cms_editable_section(page: @page, section: "hero") do %>
  <section class="bg-brand-bg">
    <div class="max-w-6xl mx-auto px-4 py-20 md:py-24">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-primary">
        <%= editable_content("hero", "eyebrow") %>
      </p>
      <h1 class="mt-4 text-4xl md:text-6xl font-extrabold tracking-tight max-w-3xl">
        <%= editable_content("hero", "heading") %>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-brand-ink-soft max-w-2xl">
        <%= editable_content("hero", "subheading") %>
      </p>
    </div>
  </section>
<% end %>

<%= cms_editable_section(page: @page, section: "offerings") do %>
  <section class="border-t border-brand-rule bg-white">
    <div class="max-w-6xl mx-auto px-4 py-20">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
        <%= editable_content("offerings", "heading") %>
      </h2>

      <%= cards_section("offerings", grid_cols: 2) %>
    </div>
  </section>
<% end %>
