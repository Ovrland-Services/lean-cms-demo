# Secrets defined here are available for reference under registry/password,
# env/secret, builder/secrets, and accessories/*/env/secret in config/deploy.yml.
# All secrets should be pulled from a password manager, ENV, or a file —
# DO NOT ENTER RAW CREDENTIALS HERE. This file is checked into git.

# GitHub Container Registry password — pulled from .env (gitignored).
# Add `KAMAL_REGISTRY_PASSWORD=ghp_…` to .env. The token needs `write:packages`
# scope on ghcr.io.
KAMAL_REGISTRY_PASSWORD=$(grep KAMAL_REGISTRY_PASSWORD .env | cut -d '=' -f2)

# Rails master key for production credentials (secret_key_base, etc).
RAILS_MASTER_KEY=$(cat config/master.key)
